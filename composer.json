{
    "name": "phptest/laravel-api",
    "description": "Laravel API for Student CRUD",
    "type": "project",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-root-package-install": ["@php -r \"file_exists('.env') || copy('.env.example', '.env');\""]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
